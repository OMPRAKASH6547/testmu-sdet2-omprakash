{
  "name": "testmu-sdet2-omprakash",
  "version": "1.0.0",
  "description": "Enterprise Playwright + TypeScript automation framework for TestMu AI SDET-2 Challenge",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:integration": "playwright test tests/integration",
    "test:smoke": "playwright test --grep @smoke",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:ci": "cross-env CI=true ENV=qa playwright test",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "test-automation",
    "sdet",
    "allure"
  ],
  "author": "Omprakash",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.33.0",
    "allure-playwright": "^3.2.0",
    "axios": "^1.8.4",
    "axios-mock-adapter": "^2.1.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
